# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
# macOS / iCloud "Finder duplicate" files: "foo 2.csv", "bar 3.png", "baz copy.txt".
* 2.*
* 3.*
* 4.*
* 5.*
* copy.*
* copy

# Jupyter
.ipynb_checkpoints/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Project-specific generated artifacts. The directory scaffolding is preserved
# via .gitkeep files so the pipeline can write into these locations on a fresh
# clone, but the actual artifacts are ignored.
data/raw_videos/*
!data/raw_videos/.gitkeep

data/frames/*
!data/frames/.gitkeep

data/mock_videos/*
!data/mock_videos/.gitkeep

data/processed/*
!data/processed/.gitkeep

outputs/annotated_frames/*
!outputs/annotated_frames/.gitkeep

outputs/annotated_videos/*
!outputs/annotated_videos/.gitkeep

outputs/detections/*
!outputs/detections/.gitkeep

outputs/tracks/*
!outputs/tracks/.gitkeep

outputs/motion/*
!outputs/motion/.gitkeep

outputs/plots/*
!outputs/plots/.gitkeep

outputs/summaries/*
!outputs/summaries/.gitkeep

outputs/hazards/*
!outputs/hazards/.gitkeep

outputs/alerts/*
!outputs/alerts/.gitkeep

outputs/evaluation/*
!outputs/evaluation/.gitkeep

outputs/slide_assets/*
!outputs/slide_assets/.gitkeep

# Manual label templates are generated by the pipeline, the final filled-in
# hazard_labels.csv (no _template suffix) is intentionally NOT ignored so
# real labels can be committed.
data/labels/*_template.csv

# YOLO weights (downloaded at runtime). Keep out of git.
*.pt
